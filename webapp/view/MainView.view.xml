<mvc:View
    xmlns:core="sap.ui.core"
    controllerName="com.example.meinetodolistenapp.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page
        id="mainview--container"
        title="{i18n>title}"
    >
        <content>
            <!-- Table of Todo Tasks -->
            <Table
                id="todoTable"
                items="{/Todo}"
            >
                <headerToolbar>
                    <!-- Headerbar -->
                    <core:Fragment
                        fragmentName="meinetodolistenapp.view.fragments.toolbar.HeaderToolbar"
                        type="XML"
                    />
                </headerToolbar>
                <columns>
                    <Column
                        id="iconCol"
                        width="12rem"
                    >
                        <Text text="{i18n>column.icon}" />
                    </Column>
                    <Column id="titleCol">
                        <Text text="{i18n>column.title}" />
                    </Column>
                    <Column id="descriptionCol">
                        <Text text="{i18n>column.description}" />
                    </Column>
                    <Column id="dueDateCol">
                        <Text text="{i18n>column.dueDate}" />
                    </Column>
                    <Column id="statusCol">
                        <Text text="{i18n>column.status}" />
                    </Column>
                    <Column id="actionCol">
                        <Text text="{i18n>column.action}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem id="todoItem">
                        <cells>
                            <core:Icon
                                src="sap-icon://task"
                                color="orange"
                            />
                            <Text text="{TITLE}" />
                            <Text text="{DESCRIPTION}" />
                            <Text
                                text="{
                                    path: 'DUE_DATE',
                                    formatter: '.formatDate'                            
                             }"
                            />
                            <ObjectStatus
                                text="{STATUS}"
                                state="{path: 'STATUS', formatter: '.getStatusState'}"
                            />

                            <core:Fragment
                                fragmentName="meinetodolistenapp.view.fragments.table.ActionButtons"
                                type="XML"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
