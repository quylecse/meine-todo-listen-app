<mvc:View
    xmlns:core="sap.ui.core"
    controllerName="meinetodolistenapp.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page
        id="mainview--container"
        title="{i18n>title}"
    >
        <content>
            <!-- Table of Todo Tasks -->
            <Table
                id="todoTable"
                items="{/Todo}"
            >
                <headerToolbar>
                    <!-- Headerbar -->
                    <core:Fragment
                        fragmentName="meinetodolistenapp.view.fragments.HeaderToolbar"
                        type="XML"
                    />
                </headerToolbar>
                <columns>
                    <Column
                        id="iconCol"
                        width="12rem"
                    >
                        <!-- cl1 -->
                        <Text text="{i18n>column.icon}" />
                    </Column>
                    <Column id="column2">
                        <!-- cl2 -->
                        <Text
                            id="titleCol"
                            text="{i18n>column.title}"
                        />
                    </Column>
                    <Column id="column3">
                        <!-- cl3 -->
                        <Text
                            id="descriptionCol"
                            text="{i18n>column.description}"
                        />
                    </Column>
                    <Column id="column4">
                        <!-- cl5 -->
                        <Text
                            id="dueDateCol"
                            text="{i18n>column.dueDate}"
                        />
                    </Column>
                    <Column id="column5">
                        <!-- cl4 -->
                        <Text
                            id="statusCol"
                            text="{i18n>column.status}"
                        />
                    </Column>
                    <Column id="column6">
                        <!-- cl6 -->
                        <Text
                            id="actionCol"
                            text="{i18n>column.action}"
                        />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem id="todoItem">
                        <cells>
                            <core:Icon
                                src="sap-icon://task"
                                color="orange"
                            />
                            <Text text="{TITLE}" />
                            <Text text="{DESCRIPTION}" />
                            <Text
                                text="{
                                    path: 'DUE_DATE',
                                    formatter: '.formatDate'                            
                             }"
                            />
                            <ObjectStatus
                                text="{STATUS}"
                                state="{path: 'STATUS', formatter: '.getStatusState'}"
                            />

                            <core:Fragment
                                fragmentName="meinetodolistenapp.view.fragments.ActionButtons"
                                type="XML"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
