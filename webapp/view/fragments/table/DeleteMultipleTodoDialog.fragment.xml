<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        type="Message"
        title="{i18n>deleteMultipleTodoButton.Title}"
    >
        <content>
            <Text
                id="multipleDeleteText"
                wrapping="true"
                text="{i18n>deleteMultipleTodoButton.content}"
            />
        </content>
        <beginButton>
            <Button
                type="Emphasized"
                text="{i18n>beginButton.deleteConfirmText}"
                press=".onConfirmMultipleDelete"
            />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>endButton.cancelText}"
                press=".onCancelDelete"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
